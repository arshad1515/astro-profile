---
const experiences = [
  {
    company:  'Daytona Systems India Pvt. Ltd.',
    role:     'Software Engineer – L2',
    period:   'Sep 2022 – Present',
    duration: '3+ years',
    location: 'Bengaluru, India',
    type:     'Full-time',
    current:  true,
    tech:     ['React.js', 'Angular 16', 'Vue.js', 'Redux Saga', 'Material UI', 'TypeScript', 'REST APIs'],
    highlights: [
      'Developed and maintained enterprise-scale fintech & banking applications using React.js, Redux, Redux Saga, and Material UI.',
      'Built secure, scalable UI components for banking workflows, fraud monitoring, transaction management, and approval systems.',
      'Integrated REST APIs for payments, customer onboarding, transaction history, compliance, and account management.',
      'Implemented complex state management solutions using Redux Saga, Redux Thunk, and Context API.',
      'Optimised application performance through lazy loading, modular components, and API optimisation.',
      'Led Agile/Scrum sprints, code reviews, and multi-environment deployments (Dev → QA → Staging → Production).',
    ],
  },
  {
    company:  'Webshark Web Services Pvt. Ltd.',
    role:     'Web Developer',
    period:   'Jan 2021 – Sep 2022',
    duration: '1 yr 9 mos',
    location: 'Bengaluru, India',
    type:     'Full-time',
    current:  false,
    tech:     ['WordPress', 'WooCommerce', 'Elementor', 'HTML5', 'CSS3', 'JavaScript', 'Bootstrap', 'jQuery'],
    highlights: [
      'Developed multiple responsive WordPress websites for e-commerce, healthcare, real estate, and retail sectors.',
      'Built WooCommerce-based e-commerce platforms with payment gateway integrations.',
      'Customised WordPress themes and plugins based on client requirements.',
      'Delivered responsive landing pages using HTML5, CSS3, Bootstrap, JavaScript, and jQuery.',
      'Improved website SEO, speed optimisation, and mobile responsiveness across all projects.',
    ],
  },
  {
    company:  'teamOxio Technologies Private Limited',
    role:     'Web Developer',
    period:   'Feb 2020 – Feb 2021',
    duration: '1 yr 1 mo',
    location: 'Amritsar / Ludhiana, India',
    type:     'Full-time',
    current:  false,
    tech:     ['HTML5', 'CSS3', 'JavaScript', 'Bootstrap'],
    highlights: [
      'Developed and maintained web interfaces for client projects.',
      'Built responsive layouts and implemented UI/UX improvements.',
    ],
  },
  {
    company:  'Chegg Inc.',
    role:     'Managed Network Expert',
    period:   'Jul 2020 – Dec 2021',
    duration: '1 yr 6 mos',
    location: 'India',
    type:     'Part-time',
    current:  false,
    tech:     ['Networking', 'Cisco'],
    highlights: [
      'Provided expert-level support in networking and technical subjects.',
    ],
  },
];
---

<section class="experience" id="experience">
  <div class="container">
    <div class="exp-header" data-observe>
      <span class="section-eyebrow">Work History</span>
      <h2 class="section-title">Professional <span>Experience</span></h2>
      <p class="section-desc">
        5+ years building production-grade applications across fintech, banking, enterprise, and CMS domains.
      </p>
    </div>

    <div class="timeline">
      {experiences.map((exp, i) => (
        <article class={`timeline-item delay-${i+1}`} data-observe>
          <!-- Timeline dot & line -->
          <div class="timeline-left">
            <div class={`tl-dot ${exp.current ? 'tl-dot--active' : ''}`} aria-hidden="true">
              {exp.current && <span class="tl-pulse"></span>}
            </div>
            {i < experiences.length - 1 && <div class="tl-line"></div>}
          </div>

          <!-- Card -->
          <div class="timeline-card card">
            <div class="tc-header">
              <div class="tc-meta">
                <div class="tc-role-row">
                  <h3 class="tc-role">{exp.role}</h3>
                  {exp.current && <span class="current-badge">Current</span>}
                </div>
                <p class="tc-company">{exp.company}</p>
                <div class="tc-details">
                  <span>
                    <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="3" y="4" width="18" height="18" rx="2" ry="2"/><line x1="16" y1="2" x2="16" y2="6"/><line x1="8" y1="2" x2="8" y2="6"/><line x1="3" y1="10" x2="21" y2="10"/></svg>
                    {exp.period}
                  </span>
                  <span>·</span>
                  <span>{exp.duration}</span>
                  <span>·</span>
                  <span>
                    <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0 1 18 0z"/><circle cx="12" cy="10" r="3"/></svg>
                    {exp.location}
                  </span>
                  <span>·</span>
                  <span>{exp.type}</span>
                </div>
              </div>
            </div>

            <ul class="tc-bullets">
              {exp.highlights.map(h => (
                <li>
                  <span class="bullet-dot" aria-hidden="true">▹</span>
                  {h}
                </li>
              ))}
            </ul>

            <div class="tc-tech">
              {exp.tech.map(t => <span class="tag">{t}</span>)}
            </div>
          </div>
        </article>
      ))}
    </div>
  </div>
</section>

<style>
  .experience { background: var(--bg-2); }

  .exp-header { margin-bottom: 56px; }

  .timeline {
    display: flex;
    flex-direction: column;
    gap: 0;
  }

  .timeline-item {
    display: grid;
    grid-template-columns: 40px 1fr;
    gap: 24px;
  }

  /* Left: dot + line */
  .timeline-left {
    display: flex;
    flex-direction: column;
    align-items: center;
    padding-top: 28px;
  }

  .tl-dot {
    position: relative;
    width: 14px;
    height: 14px;
    border-radius: 50%;
    background: var(--bg-3);
    border: 2px solid var(--text-muted);
    flex-shrink: 0;
    z-index: 1;
  }
  .tl-dot--active {
    background: var(--green);
    border-color: var(--green);
    box-shadow: 0 0 12px var(--green-glow);
  }
  .tl-pulse {
    position: absolute;
    inset: -4px;
    border-radius: 50%;
    background: var(--green);
    opacity: 0.3;
    animation: pulse 2s infinite;
  }
  @keyframes pulse {
    0%,100%{transform:scale(1);opacity:0.3}
    50%{transform:scale(1.6);opacity:0}
  }
  .tl-line {
    flex: 1;
    width: 2px;
    background: var(--border);
    margin: 8px 0;
    min-height: 40px;
  }

  /* Card */
  .timeline-card {
    padding: 28px;
    margin-bottom: 28px;
  }

  .tc-header { margin-bottom: 20px; }

  .tc-role-row {
    display: flex;
    align-items: center;
    gap: 12px;
    flex-wrap: wrap;
    margin-bottom: 4px;
  }

  .tc-role {
    font-size: 1.15rem;
    font-weight: 700;
    color: var(--white);
  }

  .current-badge {
    padding: 3px 10px;
    background: var(--green-dim);
    color: var(--green);
    border: 1px solid rgba(0,208,132,0.25);
    border-radius: 100px;
    font-size: 0.7rem;
    font-weight: 700;
    letter-spacing: 0.5px;
  }

  .tc-company {
    font-size: 0.95rem;
    font-weight: 600;
    color: var(--green);
    margin-bottom: 8px;
  }

  .tc-details {
    display: flex;
    align-items: center;
    gap: 8px;
    flex-wrap: wrap;
    font-size: 0.8rem;
    color: var(--text-muted);
  }
  .tc-details svg { margin-right: 4px; vertical-align: middle; }

  .tc-bullets {
    display: flex;
    flex-direction: column;
    gap: 8px;
    margin-bottom: 20px;
  }
  .tc-bullets li {
    display: flex;
    gap: 10px;
    font-size: 0.88rem;
    color: var(--text-dim);
    line-height: 1.6;
  }
  .bullet-dot { color: var(--green); flex-shrink: 0; margin-top: 1px; }

  .tc-tech { display: flex; flex-wrap: wrap; gap: 8px; }

  @media (max-width: 600px) {
    .timeline-item { grid-template-columns: 24px 1fr; gap: 14px; }
    .tl-dot { width: 10px; height: 10px; }
    .timeline-card { padding: 20px; }
  }
</style>
