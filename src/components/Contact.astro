const socials = [
  {
    name: 'LinkedIn',
    url:  'https://www.linkedin.com/in/arshad-ali-software-engineer/',
    handle: 'arshad-ali-software-engineer',
    icon: `<svg width="22" height="22" viewBox="0 0 24 24" fill="currentColor"><path d="M16 8a6 6 0 0 1 6 6v7h-4v-7a2 2 0 0 0-2-2 2 2 0 0 0-2 2v7h-4v-7a6 6 0 0 1 6-6z"/><rect x="2" y="9" width="4" height="12"/><circle cx="4" cy="4" r="2"/></svg>`,
    color: '#0A66C2',
  },
  {
    name: 'Email',
    url:  'mailto:arshadali1515@gmail.com',
    handle: 'arshadali1515@gmail.com',
    icon: `<svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z"/><polyline points="22,6 12,13 2,6"/></svg>`,
    color: '#EA4335',
  },
  {
    name: 'Phone',
    url:  'tel:+918427041280',
    handle: '+91 84270 41280',
    icon: `<svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07A19.5 19.5 0 0 1 4.15 12 19.79 19.79 0 0 1 1.07 3.36a2 2 0 0 1 1.95-2.18h3a2 2 0 0 1 2 1.72 12.84 12.84 0 0 0 .7 2.81 2 2 0 0 1-.45 2.11L7.91 8.25a16 16 0 0 0 6 6l.27-.27a2 2 0 0 1 2.11-.45 12.84 12.84 0 0 0 2.81.7A2 2 0 0 1 22 16.92z"/></svg>`,
    color: '#00D084',
  },
];
---

<section class="contact" id="contact">
  <div class="container">
    <div class="contact-header" data-observe>
      <span class="section-eyebrow">Get In Touch</span>
      <h2 class="section-title">Let's Work <span>Together</span></h2>
      <p class="section-desc">
        I'm currently open to new opportunities. Whether you have a project,
        a role, or just want to connect — my inbox is always open.
      </p>
    </div>

    <div class="contact-grid">
      <!-- Left: Form -->
      <div class="contact-form-wrap" data-observe>
        <form
          class="contact-form"
          id="contact-form"
          method="POST"
          action="https://arshadali.in"
          novalidate
        >
         <input
        type="hidden"
        name="access_key"
        value={WEB3FORMS_KEY}
      />

      <input
        type="hidden"
        name="subject"
        value="New Portfolio Contact Form Submission"
      />
          <input type="hidden" name="_subject" value="Portfolio Contact — Arshad Ali" />

          <div class="form-row">
            <div class="cf-group">
              <label for="cf-name">Your Name <span>*</span></label>
              <input type="text" id="cf-name" name="name" placeholder="Jane Smith" required autocomplete="name" />
            </div>
            <div class="cf-group">
              <label for="cf-email">Email Address <span>*</span></label>
              <input type="email" id="cf-email" name="email" placeholder="jane@company.com" required autocomplete="email" />
            </div>
          </div>

          <div class="cf-group">
            <label for="cf-subject">Subject <span>*</span></label>
            <input type="text" id="cf-subject" name="subject" placeholder="Job Opportunity / Project Collaboration" required />
          </div>

          <div class="cf-group">
            <label for="cf-message">Message <span>*</span></label>
            <textarea id="cf-message" name="message" rows="5" placeholder="Tell me about the role or project..." required></textarea>
          </div>

          <button type="submit" class="btn btn-primary submit-btn" id="cf-submit">
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><line x1="22" y1="2" x2="11" y2="13"/><polygon points="22 2 15 22 11 13 2 9 22 2"/></svg>
            Send Message
          </button>

        </form>
      </div>

      <!-- Right: Info + Socials -->
      <div class="contact-info" data-observe class="delay-2">
        <div class="info-card card">
          <h3 class="info-title">Direct Contact</h3>
          <p class="info-desc">
            Prefer a direct reach? Connect through any of these channels.
            I typically respond within 24 hours.
          </p>

          <div class="socials">
            {socials.map(s => (
              <a
                href={s.url}
                target={s.url.startsWith('http') ? '_blank' : undefined}
                rel={s.url.startsWith('http') ? 'noopener noreferrer' : undefined}
                class="social-item"
                aria-label={`${s.name}: ${s.handle}`}
              >
                <div class="social-icon-wrap" style={`background:${s.color}18;color:${s.color}`}>
                  <Fragment set:html={s.icon} />
                </div>
                <div>
                  <span class="social-name">{s.name}</span>
                  <span class="social-handle">{s.handle}</span>
                </div>
                <svg class="social-arrow" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
              </a>
            ))}
          </div>
        </div>

        <div class="avail-card">
          <div class="avail-dot" aria-hidden="true"></div>
          <div>
            <p class="avail-title">Currently Available</p>
            <p class="avail-desc">Open to full-time roles, contract projects, and freelance work in frontend development.</p>
          </div>
        </div>
      </div>
    </div>
  </div>
</section>

<script>
  document.addEventListener('DOMContentLoaded', () => {
    const form = document.getElementById('contact-form');
    const btn = document.getElementById('cf-submit');
    const success = document.getElementById('cf-success');

    form?.addEventListener('submit', async (e) => {
      e.preventDefault();

      if (!btn) return;

      btn.textContent = 'Sending...';
      btn.disabled = true;

      try {
        const formData = new FormData(form);

        const response = await fetch(
          'https://api.web3forms.com/submit',
          {
            method: 'POST',
            body: formData,
            headers: {
              Accept: 'application/json'
            }
          }
        );

        const result = await response.json();

        console.log(result);

        if (result.success) {
          form.reset();
          success?.removeAttribute('hidden');
          btn.textContent = 'Message Sent ✓';
        } else {
          console.error(result);
          btn.textContent = 'Try Again';
          btn.disabled = false;
        }
      } catch (error) {
        console.error(error);
        btn.textContent = 'Try Again';
        btn.disabled = false;
      }
    });
  });
</script>

<style>
  .contact { background: var(--bg-2); }

  .contact-header { margin-bottom: 56px; }

  .contact-grid {
    display: grid;
    grid-template-columns: 1.1fr 0.9fr;
    gap: 48px;
    align-items: start;
  }

  /* Form */
  .contact-form { display: flex; flex-direction: column; gap: 20px; }

  .form-row { display: grid; grid-template-columns: 1fr 1fr; gap: 16px; }

  .cf-group { display: flex; flex-direction: column; gap: 6px; }

  .cf-group label {
    font-size: 0.82rem;
    font-weight: 600;
    color: var(--text-dim);
  }
  .cf-group label span { color: var(--green); }

  .cf-group input,
  .cf-group textarea {
    background: var(--bg-card);
    border: 1.5px solid var(--border);
    border-radius: 8px;
    padding: 12px 16px;
    font-family: var(--font-sans);
    font-size: 0.9rem;
    color: var(--text);
    outline: none;
    transition: border-color 0.2s, box-shadow 0.2s;
    resize: vertical;
  }
  .cf-group input:focus,
  .cf-group textarea:focus {
    border-color: var(--green);
    box-shadow: 0 0 0 3px var(--green-dim);
  }
  .cf-group input::placeholder,
  .cf-group textarea::placeholder { color: var(--text-muted); }

  .submit-btn { width: 100%; justify-content: center; padding: 15px; }
  .submit-btn:disabled { opacity: 0.6; cursor: not-allowed; }

  .form-success-msg {
    display: flex;
    align-items: center;
    gap: 10px;
    padding: 14px 18px;
    background: var(--green-dim);
    border: 1px solid rgba(0,208,132,0.25);
    border-radius: 8px;
    font-size: 0.9rem;
    color: var(--green);
    font-weight: 500;
  }

  /* Right */
  .info-card { padding: 28px; margin-bottom: 20px; }
  .info-title { font-size: 1.1rem; font-weight: 700; color: var(--white); margin-bottom: 10px; }
  .info-desc  { font-size: 0.88rem; color: var(--text-muted); line-height: 1.65; margin-bottom: 24px; }

  .socials { display: flex; flex-direction: column; gap: 12px; }

  .social-item {
    display: flex;
    align-items: center;
    gap: 14px;
    padding: 14px 16px;
    border-radius: 10px;
    background: var(--bg-3);
    border: 1px solid var(--border);
    transition: background 0.2s, border-color 0.2s, transform 0.2s;
  }
  .social-item:hover {
    background: rgba(255,255,255,0.04);
    border-color: rgba(0,208,132,0.2);
    transform: translateX(4px);
  }

  .social-icon-wrap {
    width: 40px;
    height: 40px;
    border-radius: 10px;
    display: flex;
    align-items: center;
    justify-content: center;
    flex-shrink: 0;
  }

  .social-name   { display: block; font-size: 0.82rem; font-weight: 700; color: var(--white); }
  .social-handle { display: block; font-size: 0.75rem; color: var(--text-muted); margin-top: 1px; }

  .social-arrow { margin-left: auto; color: var(--text-muted); flex-shrink: 0; }

  .avail-card {
    display: flex;
    align-items: flex-start;
    gap: 14px;
    padding: 20px;
    background: var(--green-dim);
    border: 1px solid rgba(0,208,132,0.2);
    border-radius: var(--radius);
  }
  .avail-dot {
    width: 10px;
    height: 10px;
    border-radius: 50%;
    background: var(--green);
    box-shadow: 0 0 10px var(--green);
    flex-shrink: 0;
    margin-top: 5px;
    animation: blink 2s infinite;
  }
  .avail-title { font-size: 0.9rem; font-weight: 700; color: var(--green); margin-bottom: 4px; }
  .avail-desc  { font-size: 0.82rem; color: var(--text-dim); line-height: 1.6; }

  @media (max-width: 860px) {
    .contact-grid { grid-template-columns: 1fr; }
    .form-row { grid-template-columns: 1fr; }
  }
</style>
