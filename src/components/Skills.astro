---
const skillGroups = [
  {
    title: 'Frontend Frameworks',
    icon: '⚛️',
    skills: [
      { name: 'React.js',     level: 95 },
      { name: 'Angular 16',   level: 88 },
      { name: 'Vue.js',       level: 85 },
      { name: 'TypeScript',   level: 90 },
      { name: 'JavaScript ES6+', level: 95 },
    ],
  },
  {
    title: 'UI & Styling',
    icon: '🎨',
    skills: [
      { name: 'Material UI (MUI)', level: 92 },
      { name: 'Tailwind CSS',      level: 85 },
      { name: 'Bootstrap',         level: 90 },
      { name: 'SCSS / CSS3',       level: 92 },
      { name: 'HTML5',             level: 97 },
    ],
  },
  {
    title: 'State & Data',
    icon: '🔄',
    skills: [
      { name: 'Redux + Saga',  level: 90 },
      { name: 'Redux Thunk',   level: 88 },
      { name: 'Context API',   level: 90 },
      { name: 'Formik + Yup',  level: 85 },
      { name: 'AG Grid',       level: 80 },
    ],
  },
  {
    title: 'Tools & Ecosystem',
    icon: '🛠️',
    skills: [
      { name: 'Git',           level: 92 },
      { name: 'REST APIs / Axios', level: 93 },
      { name: 'Webpack / Babel',   level: 80 },
      { name: 'JIRA / Agile',      level: 88 },
      { name: 'WordPress / WooCommerce', level: 85 },
    ],
  },
];

const techTags = [
  'React.js','Angular 16','Vue.js','TypeScript','JavaScript',
  'Redux','Redux Saga','Material UI','Tailwind CSS','Bootstrap',
  'SCSS','HTML5','CSS3','Formik','Yup','AG Grid','Axios','Git',
  'Webpack','JIRA','WordPress','Elementor','WooCommerce','REST API',
  'Postman','VS Code','npm','ESLint','Prettier','Babel',
];
---

<section class="skills" id="skills">
  <div class="container">
    <!-- Header -->
    <div class="skills-header" data-observe>
      <span class="section-eyebrow">Technical Skills</span>
      <h2 class="section-title">My <span>Tech Stack</span></h2>
      <p class="section-desc">
        5+ years of hands-on experience across the full frontend spectrum —
        from pixel-perfect UI to complex state machines and API architectures.
      </p>
    </div>

    <!-- Skill groups grid -->
    <div class="skills-grid">
      {skillGroups.map((group, gi) => (
        <div class={`skill-group card delay-${gi+1}`} data-observe>
          <div class="group-head">
            <span class="group-icon" aria-hidden="true">{group.icon}</span>
            <h3 class="group-title">{group.title}</h3>
          </div>
          <ul class="skill-list">
            {group.skills.map(s => (
              <li class="skill-row">
                <div class="skill-top">
                  <span class="skill-name">{s.name}</span>
                  <span class="skill-pct mono">{s.level}%</span>
                </div>
                <div class="skill-bar-track" role="progressbar" aria-valuenow={s.level} aria-valuemin={0} aria-valuemax={100} aria-label={`${s.name} proficiency ${s.level}%`}>
                  <div class="skill-bar-fill" style={`--w:${s.level}%`}></div>
                </div>
              </li>
            ))}
          </ul>
        </div>
      ))}
    </div>

    <!-- Tech tag cloud -->
    <div class="tag-cloud" data-observe>
      <h3 class="tag-cloud-title">All Technologies</h3>
      <div class="tag-cloud-wrap">
        {techTags.map((t, i) => (
          <span class={i % 3 === 0 ? 'tag' : i % 3 === 1 ? 'tag tag-blue' : 'tag'} style={i % 3 === 1 ? '' : ''}>
            {t}
          </span>
        ))}
      </div>
    </div>
  </div>
</section>

<style>
  .skills { background: var(--bg); }

  .skills-header {
    text-align: center;
    margin-bottom: 56px;
  }
  .skills-header .section-eyebrow { justify-content: center; }
  .skills-header .section-desc { margin: 0 auto; }

  .skills-grid {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 24px;
    margin-bottom: 48px;
  }

  .skill-group { padding: 28px; }

  .group-head {
    display: flex;
    align-items: center;
    gap: 12px;
    margin-bottom: 24px;
    padding-bottom: 16px;
    border-bottom: 1px solid var(--border);
  }
  .group-icon { font-size: 1.4rem; }
  .group-title {
    font-size: 1rem;
    font-weight: 700;
    color: var(--white);
  }

  .skill-list { display: flex; flex-direction: column; gap: 16px; }

  .skill-row {}
  .skill-top {
    display: flex;
    justify-content: space-between;
    align-items: center;
    margin-bottom: 6px;
  }
  .skill-name { font-size: 0.875rem; font-weight: 500; color: var(--text); }
  .skill-pct  { font-size: 0.75rem; color: var(--green); }

  .skill-bar-track {
    height: 5px;
    background: rgba(255,255,255,0.06);
    border-radius: 100px;
    overflow: hidden;
  }
  .skill-bar-fill {
    height: 100%;
    width: 0;
    background: linear-gradient(90deg, var(--green), var(--blue));
    border-radius: 100px;
    transition: width 1.2s cubic-bezier(0.4, 0, 0.2, 1);
  }

  /* Animate bars when card enters view */
  .skill-group.in-view .skill-bar-fill { width: var(--w); }

  /* Tag cloud */
  .tag-cloud {
    padding: 36px;
    background: var(--bg-card);
    border: 1px solid var(--border);
    border-radius: var(--radius-lg);
    text-align: center;
  }
  .tag-cloud-title {
    font-size: 1rem;
    font-weight: 700;
    color: var(--text-muted);
    margin-bottom: 20px;
    text-transform: uppercase;
    letter-spacing: 2px;
    font-size: 0.75rem;
  }
  .tag-cloud-wrap {
    display: flex;
    flex-wrap: wrap;
    gap: 10px;
    justify-content: center;
  }
  .tag-cloud-wrap .tag { padding: 6px 16px; font-size: 0.8rem; cursor: default; transition: transform 0.2s; }
  .tag-cloud-wrap .tag:hover { transform: scale(1.08); }

  @media (max-width: 768px) {
    .skills-grid { grid-template-columns: 1fr; }
  }
</style>
