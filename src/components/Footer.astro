---
const year = new Date().getFullYear();
---

<footer class="site-footer">
  <div class="container footer-inner">
    <div class="footer-left">
      <a href="/" class="footer-logo" aria-label="Arshad Ali - Home">
        <span class="mono" style="color:var(--green)">&lt;</span>
        <span style="color:var(--white);font-weight:700">Arshad</span>
        <span class="mono" style="color:var(--green)">/&gt;</span>
      </a>
      <p class="footer-tagline">Senior Frontend Developer · React.js · Angular · Vue.js</p>
      <p class="footer-copy">&copy; {year} Arshad Ali. Built with Astro.js.</p>
    </div>

    <nav class="footer-nav" aria-label="Footer navigation">
      <a href="#about">About</a>
      <a href="#skills">Skills</a>
      <a href="#experience">Experience</a>
      <a href="#projects">Projects</a>
      <a href="#contact">Contact</a>
    </nav>

    <div class="footer-socials">
      <a
        href="https://www.linkedin.com/in/arshad-ali-software-engineer/"
        target="_blank"
        rel="noopener noreferrer"
        class="social-link"
        aria-label="LinkedIn"
      >
        <svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor"><path d="M16 8a6 6 0 0 1 6 6v7h-4v-7a2 2 0 0 0-2-2 2 2 0 0 0-2 2v7h-4v-7a6 6 0 0 1 6-6z"/><rect x="2" y="9" width="4" height="12"/><circle cx="4" cy="4" r="2"/></svg>
      </a>
      <a href="mailto:arshadali1515@gmail.com" class="social-link" aria-label="Email">
        <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z"/><polyline points="22,6 12,13 2,6"/></svg>
      </a>
      <a href="tel:+918427041280" class="social-link" aria-label="Phone">
        <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07A19.5 19.5 0 0 1 4.15 12 19.79 19.79 0 0 1 1.07 3.36a2 2 0 0 1 1.95-2.18h3a2 2 0 0 1 2 1.72 12.84 12.84 0 0 0 .7 2.81 2 2 0 0 1-.45 2.11L7.91 8.25a16 16 0 0 0 6 6l.27-.27a2 2 0 0 1 2.11-.45 12.84 12.84 0 0 0 2.81.7A2 2 0 0 1 22 16.92z"/></svg>
      </a>
    </div>
  </div>

  <!-- Back to top -->
  <button class="back-top" id="back-top" aria-label="Back to top">
    <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><polyline points="18 15 12 9 6 15"/></svg>
  </button>
</footer>

<script>
  const btn = document.getElementById('back-top');
  window.addEventListener('scroll', () => {
    btn?.classList.toggle('visible', window.scrollY > 400);
  }, { passive: true });
  btn?.addEventListener('click', () => window.scrollTo({ top: 0, behavior: 'smooth' }));
</script>

<style>
  .site-footer {
    background: var(--bg);
    border-top: 1px solid var(--border);
    padding: 48px 0 32px;
    position: relative;
  }

  .footer-inner {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 32px;
    flex-wrap: wrap;
  }

  .footer-logo {
    font-size: 1.1rem;
    display: inline-flex;
    gap: 3px;
    align-items: center;
    margin-bottom: 8px;
  }

  .footer-tagline {
    font-size: 0.82rem;
    color: var(--text-muted);
    margin-bottom: 6px;
  }
  .footer-copy {
    font-size: 0.78rem;
    color: var(--text-muted);
    opacity: 0.6;
  }

  .footer-nav {
    display: flex;
    gap: 20px;
    flex-wrap: wrap;
  }
  .footer-nav a {
    font-size: 0.85rem;
    color: var(--text-muted);
    transition: color 0.2s;
  }
  .footer-nav a:hover { color: var(--green); }

  .footer-socials { display: flex; gap: 12px; }

  .social-link {
    width: 38px;
    height: 38px;
    border-radius: 8px;
    background: var(--bg-card);
    border: 1px solid var(--border);
    display: flex;
    align-items: center;
    justify-content: center;
    color: var(--text-muted);
    transition: color 0.2s, border-color 0.2s, background 0.2s;
  }
  .social-link:hover {
    color: var(--green);
    border-color: rgba(0,208,132,0.3);
    background: var(--green-dim);
  }

  /* Back to top */
  .back-top {
    position: fixed;
    bottom: 28px;
    right: 28px;
    width: 44px;
    height: 44px;
    border-radius: 10px;
    background: var(--green);
    color: #000;
    border: none;
    cursor: pointer;
    display: flex;
    align-items: center;
    justify-content: center;
    box-shadow: 0 4px 20px var(--green-glow);
    opacity: 0;
    transform: translateY(12px);
    transition: opacity 0.3s, transform 0.3s;
    z-index: 50;
  }
  .back-top.visible { opacity: 1; transform: none; }
  .back-top:hover   { background: #00e891; }

  @media (max-width: 640px) {
    .footer-inner { flex-direction: column; align-items: flex-start; }
  }
</style>
